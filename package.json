{
  "name": "aletheia-platform-qwik",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode ssr",
    "build.client": "vite build",
    "build.server": "vite build -c adapters/node-server/vite.config.ts",
    "build": "npm run build.client && npm run build.server",
    "build.vercel": "npm run build.client && vite build -c adapters/vercel-edge/vite.config.ts",
    "serve": "node server/entry.node-server",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@types/node": "^25.5.0",
    "@vercel/analytics": "^2.0.1",
    "ignore": "^7.0.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17"
  }
}
